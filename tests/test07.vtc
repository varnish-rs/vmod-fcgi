varnishtest "fastcgi backend: POST request with chunked encoding"

shell {
    set -e
    cat > "${tmpdir}/echo.cgi" <<'EOF'
#!/bin/sh
echo "Content-Type: text/plain"
echo ""
echo "CONTENT_LENGTH=$CONTENT_LENGTH"
printf "BODY="
cat
EOF
    chmod +x "${tmpdir}/echo.cgi"
}

process p1 {
    exec fcgiwrap -s "unix:${tmpdir}/fcgi.sock"
} -start

shell {
    for i in $(seq 1 50); do
        test -S "${tmpdir}/fcgi.sock" && exit 0
        sleep 0.1
    done
    echo "fcgiwrap never created its socket" >&2
    exit 1
}

varnish v1 -vcl {
    import fastcgi from "${vmod}";

    backend default none;

    sub vcl_init {
        new be1 = fastcgi.new("unix:${tmpdir}/fcgi.sock", "${tmpdir}");
    }

    sub vcl_recv {
        set req.backend_hint = be1.backend();
        return (pass);
    }
} -start

# Chunked request bodies carry no upfront Content-Length, and Varnish does not
# surface a computed one to the backend fetch for them (unlike a bodyless POST,
# where it sets "0"). This vmod deliberately doesn't derive a length from the
# body itself (see backend.rs), so a chunked POST always fails the fetch rather
# than silently mishandling the body. This is a known, documented limitation
# (see README), not a bug in the test.
client c1 {
    txreq -req POST -url "/echo.cgi" -nolen -hdr "Transfer-Encoding: chunked"
    chunked "hello=world"
    chunked ""
    rxresp
    expect resp.status == 503
} -run

process p1 -stop
