varnishtest "fastcgi backend: response body spanning multiple FastCGI records"

shell {
    set -e
    # Body over 65535 bytes (the FastCGI per-record content-length max) forces
    # fcgiwrap to split it across multiple STDOUT records, exercising the
    # vmod's read()-stash logic for leftover bytes.
    cat > "${tmpdir}/big-body.cgi" <<'EOF'
#!/bin/sh
echo "Content-Type: text/plain"
echo ""
printf "STARTSTARTSTART"
yes A | tr -d '\n' | head -c 100000
printf "ENDENDEND"
EOF
    chmod +x "${tmpdir}/big-body.cgi"
}

process p1 {
    exec fcgiwrap -s "unix:${tmpdir}/fcgi.sock"
} -start

shell {
    for i in $(seq 1 50); do
        test -S "${tmpdir}/fcgi.sock" && exit 0
        sleep 0.1
    done
    echo "fcgiwrap never created its socket" >&2
    exit 1
}

varnish v1 -vcl {
    import fastcgi from "${vmod}";

    backend default none;

    sub vcl_init {
        new be1 = fastcgi.new("unix:${tmpdir}/fcgi.sock", "${tmpdir}");
    }

    sub vcl_recv {
        set req.backend_hint = be1.backend();
        set req.http.X-Forwarded-For = "203.0.113.7";
        return (pass);
    }
} -start

client c1 {
    txreq -url "/big-body.cgi"
    rxresp
    expect resp.status == 200
    expect resp.bodylen == 100024
    expect resp.body ~ "^STARTSTARTSTART"
    expect resp.body ~ "ENDENDEND$"
} -run

process p1 -stop
